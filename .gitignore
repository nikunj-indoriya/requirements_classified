.idea/

# ==================================================
# Results — keep CSVs and analysis outputs, skip PNGs
# (PNGs are regenerated by analysis.py)
# ==================================================

# ignore everything under results/ by default
results/*

# --- raw result CSVs ---
!results/secreq_unsupervised_centroid_full.csv
!results/secreq_unsupervised_wikidominer_full.csv
!results/secreq_unsupervised_hybrid_full.csv
!results/secreq_supervised_full.csv

!results/crowdre_unsupervised_centroid_full.csv
!results/crowdre_unsupervised_wikidominer_full.csv
!results/crowdre_unsupervised_hybrid_full.csv
!results/crowdre_supervised_full.csv

!results/promise_unsupervised_centroid_full.csv
!results/promise_unsupervised_wikidominer_full.csv
!results/promise_unsupervised_hybrid_full.csv
!results/promise_supervised_full.csv

# --- analysis output folders (CSVs only, not PNGs) ---
!results/analysis/
!results/analysis/**
!results/analysis_wikidominer/
!results/analysis_wikidominer/**
!results/analysis_hybrid/
!results/analysis_hybrid/**

# re-ignore PNGs inside analysis folders
results/analysis/**/*.png
results/analysis_wikidominer/**/*.png
results/analysis_hybrid/**/*.png

# ==================================================
# Always keep these
# ==================================================
!requirements.txt
!data/
!data/**

